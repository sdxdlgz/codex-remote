# Local server bind. Keep 127.0.0.1 when using Cloudflare Tunnel.
HOST=127.0.0.1
PORT=8787

# Optional public URL shown in logs/status.
PUBLIC_URL=

# Codex process launched inside the PTY.
CODEX_REMOTE_COMMAND=codex
CODEX_REMOTE_CWD=
CODEX_REMOTE_AUTO_START=true

# Runtime behavior.
REMOTE_HISTORY_BYTES=1048576
MAX_INPUT_BYTES=8192
ALLOW_CONTROL_TAKEOVER=true

# Optional app-level login token. Recommended when Cloudflare Access is not configured yet.
REMOTE_AUTH_TOKEN=
AUTH_COOKIE_NAME=codex_remote_token

# Public-access protection. Set REQUIRE_CF_ACCESS=true before exposing via Cloudflare Tunnel.
REQUIRE_CF_ACCESS=false
ACCESS_ALLOWED_EMAILS=
ALLOWED_ORIGINS=
TRUST_PROXY=true
